# Used by dbt_churn Makefile / sqlfluff scripts. Copy to dbt_churn/.env (or repo-root .env).
# Install tooling once from repo root: uv sync --group dev --group dbt
# Matches local-db defaults from churn-prediction.

# --- Postgres (default dbt target: dev) ---
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=playground
POSTGRES_PORT=5433
POSTGRES_DATABASE=churn_prac
POSTGRES_SCHEMA=dbt_schema

# --- Athena (set DBT_TARGET=ci and fill the rest; use Terraform outputs from aws-terraform-infra) ---
# DBT_TARGET=ci
# AWS_REGION=us-east-1
# ATHENA_DATABASE=awsdatacatalog
# ATHENA_SCHEMA=dbt_churn_yourname
# ATHENA_S3_STAGING_DIR=s3://YOUR_BUCKET/athena/churn-prediction/query-results/
# ATHENA_S3_DATA_DIR=s3://YOUR_BUCKET/warehouse/dbt/
# ATHENA_WORK_GROUP=churn_prac
# Terraform must set enforce_workgroup_configuration=false on that workgroup so dbt CTAS
# can use ATHENA_ML_EXPORT_* external_location (otherwise Parquet lands only under query-results).
#
# CTAS export for SageMaker preprocess (Athena only): empty S3 prefixes, trailing slash.
# Align with Terraform fight_churn bucket, e.g. ml/exports/train/ and ml/exports/infer/.
# ATHENA_ML_EXPORT_CHURN_TRAINING_PREFIX=s3://YOUR_BUCKET/ml/exports/train/churn_training_dataset/
# ATHENA_ML_EXPORT_CURRENT_CUSTOMER_PREFIX=s3://YOUR_BUCKET/ml/exports/infer/current_customer_dataset/
