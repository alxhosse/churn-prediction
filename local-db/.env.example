# Copy to .env in this directory (local-db). docker compose reads it automatically.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=playground
POSTGRES_DB=churn_prac

# Host port: default 5433 (not 5432). GUI tools must use this port or connection is refused.
# To listen on 5432 instead, uncomment and ensure nothing else binds 5432, then docker compose up -d.
# POSTGRES_PORT=5432
